# ── CXR-CAD: 모델 가중치 (절대 커밋 금지) ────────────────────────────────────
# Colab에서 학습한 .pth / .pt 파일은 Git에 포함하지 않습니다.
checkpoints/**/*.pth
checkpoints/**/*.pt

# 데이터셋 (대용량)
