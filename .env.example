# .env.example
# 실제 키는 .env에만 넣고, .env는 Git 추적에서 제외하세요.

# =========================
# OpenAI / LLM 설정
# =========================

# OpenAI API Key
# 실제 .env 파일에만 진짜 키를 넣으세요.
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API 기본 주소
OPENAI_BASE_URL=https://api.openai.com/v1

# 사용할 LLM 모델
CXR_AGENT_LLM_MODEL=gpt-4o-mini

# LLM agent 활성화
# true이면 Agent Workbench의 후속 질문 답변에 LLM synthesis를 사용합니다.
CXR_AGENT_LLM_ENABLED=true

# LLM 우선 모드
# true이면 품질/Grad-CAM/ROI/triage/판독문 질문도 우선 LLM이 tool context를 종합해 답합니다.
CXR_AGENT_LLM_FIRST=true

# Tool-first fastpath 비활성화
# false로 두면 하드코딩된 빠른 답변보다 LLM 기반 agent 답변을 우선합니다.
# 대회 시연/데모에서는 false 추천.
CXR_AGENT_TOOL_FIRST_FASTPATH=false

# 기본 full workup
# true이면 초기 분석 시 Quality, Grad-CAM, ROI, Triage, Report context를 폭넓게 생성합니다.
# 답변 근거가 풍부해져 시연 효과가 좋아집니다.
CXR_AGENT_DEFAULT_FULL_WORKUP=true

# =========================
# Agentic Workbench LLM 옵션
# =========================

# 답변이 너무 짧지 않도록 넉넉하게 설정
CXR_AGENT_LLM_MAX_TOKENS=1200

# 로딩이 길어져도 LLM 답변을 기다리도록 설정
CXR_AGENT_LLM_TIMEOUT=90

# 의료 도메인 데모에서는 낮은 temperature 추천
CXR_AGENT_LLM_TEMPERATURE=0.1

# =========================
# Result Analysis LLM 옵션
# =========================

CXR_ANALYSIS_LLM_MAX_TOKENS=900
CXR_ANALYSIS_LLM_TIMEOUT=60
CXR_ANALYSIS_LLM_TEMPERATURE=0.15